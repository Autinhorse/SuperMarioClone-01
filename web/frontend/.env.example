# Copy to .env.local and fill in real values from Supabase dashboard:
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Server-only secret (DO NOT commit, DO NOT prefix with NEXT_PUBLIC_).
# Needed only for admin/migration tasks that bypass RLS.
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxx
